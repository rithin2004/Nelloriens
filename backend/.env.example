PORT=5000
NODE_ENV=development

# Allowed origins — comma-separated list
# Development: leave blank (localhost variants are allowed automatically)
# Production: set to your exact frontend origins
ALLOWED_ORIGINS=https://nelloriens.in,https://admin.nelloriens.in

# Firebase Storage bucket (usually <project-id>.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# One-time setup secret — required for POST /setup/create-superadmin
# Set this to a strong random string before first deploy
SETUP_SECRET=change-me-before-deploy

# Instagram Basic Display API (optional — can be configured via UI)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
