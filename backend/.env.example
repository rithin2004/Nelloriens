PORT=5000
NODE_ENV=development

# Allowed frontend origin
CLIENT_ORIGIN=http://localhost:5173

# Firebase Admin SDK — paste values from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Storage bucket (usually <project-id>.appspot.com)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# One-time setup secret — required for POST /setup/create-superadmin
# Set this to a strong random string before first deploy
SETUP_SECRET=change-me-before-deploy

# Instagram Basic Display API (optional — can be configured via UI)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
